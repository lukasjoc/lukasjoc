#!/bin/bash
set -u

__usage() {
	printf '\n%s\n\n' "Rendering/Build script. Markdown content to html with template"
	printf '%s\n\n' "USAGE:"
	printf '%s\n\n'  " ${0##*/} [ -h ] [ build ] [ serve ]"
	return 1
}

__build() {
	if ! command -v "pandoc" >/dev/null 2>&1; then
		echo "Pandoc must be installed or put in PATH since it is the rendering engine"

		exit 1
	fi
	
	local build_dir
	build_dir="$PWD"/build
		
	if [ ! -d "$build_dir"  ]; then
		mkdir -p "$build_dir"
	fi

	cp "$PWD/DroidSansMono.ttf" "$build_dir"

	for candidate in "$PWD"/pages/*.md; do
		pandoc \
			--from markdown \
			--to html "$candidate" \
			--template="$PWD"/default.html \
			-o "$build_dir/$(basename "${candidate%.*}").html"
	done

	return 0	
}

__serve() {
	docker stop lukasjoc_devel || true
	docker rm lukasjoc_devel || true
	docker build -t lukasjoc:devel -f docker/Dockerfile .
	docker run --name lukasjoc_devel -p "80:80" -d lukasjoc:devel
	return 0
}


# print help if zero args are given
if [[ "$#" == "0" ]]; then
	__usage
fi

## handle single flags upper and lowercase
declare opt
declare OPTARG
declare OPTIND
while getopts ":h" opt; do
	case ${opt} in
		h) __usage;;
		\?) echo "Invalid Option: -$OPTARG" 1>&2;;
	esac
done

declare subcmd
subcmd="${1:-}"; shift
case "$subcmd" in
	build) __build;;
	serve) __serve;;
esac


shift $((OPTIND -1))

